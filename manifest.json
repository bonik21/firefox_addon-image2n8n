{
    "manifest_version": 3,
    "name": "image2n8n",
    "version": "1.0",
    "description": "우클릭한 이미지를 base64로 변환하여 n8n으로 전송합니다.",
    "permissions": [
        "contextMenus",
        "activeTab"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}